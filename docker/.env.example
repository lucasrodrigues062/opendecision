# =============================================================================
# OpenDecision Configuration - .env.example
# Copy to .env and adjust for your environment
# =============================================================================

# Server
PORT=8080
LOG_LEVEL=info

# Storage Backend: memory | dynamo | postgres
STORE_BACKEND=dynamo

# Cache Backend: memory | redis
CACHE_BACKEND=memory
CACHE_TTL_SECONDS=300

# =============================================================================
# DYNAMO DB Configuration
# =============================================================================
# When STORE_BACKEND=dynamo

# DynamoDB endpoint (LocalStack for local dev, AWS for prod)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
DYNAMO_TABLE=pipelines

# AWS credentials (use 'test' for LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# =============================================================================
# REDIS Configuration (optional, if CACHE_BACKEND=redis)
# =============================================================================

REDIS_URL=redis://localhost:6379/0

# =============================================================================
# POSTGRES Configuration (not used yet, for future)
# =============================================================================

# DATABASE_URL=postgres://opendecision:opendecision@localhost:5432/opendecision
